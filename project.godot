; Engine configuration file — The Situation Room
;
; Main project file. Bunker dashboard / AI agent monitor.
; Engine: Godot 4.6.2 (per docs/engine-reference/godot/VERSION.md)
;
; Architecture reference: docs/architecture/control-manifest.md
; Design reference:       design/gdd/systems-index.md
; First implementation:   ConfigurationLoader (commit f43... — Sprint 2 day 1)
;
; Subdirectories with their own project.godot (prototypes/data-bridge/,
; prototypes/acc-legibility/) are skipped via .gdignore files in their
; directories — they are separate Godot projects, not part of the main build.

config_version=5

[application]

config/name="The Situation Room"
config/description="Real-time AI agent monitoring dashboard with a top-down pixel-art bunker aesthetic. Personal developer tool — see HOME.md."
run/main_scene=""
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

; Per ADR-0003 — only two Autoloads ship in MVP.
; Order matters: ConfigurationLoader must initialise first so AudioManager
; can read settings from it during AudioManager._ready().
ConfigurationLoader="*res://src/core/configuration_loader.gd"
; AudioManager (next sprint) will be registered here when implemented:
; AudioManager="*res://src/core/audio_manager.gd"

[display]

; Per ADR-0013 — viewport 480×270, integer scaling, allow HiDPI on Retina.
window/size/viewport_width=480
window/size/viewport_height=270
window/size/window_width_override=1920
window/size/window_height_override=1080
window/stretch/mode="viewport"
window/stretch/aspect="keep"
window/stretch/scale_mode="integer"
window/dpi/allow_hidpi=true

[input]

; Per ADR-0011 — HUD toggle, default Tab. Remappable per accessibility-requirements §2.3.
toggle_hud={
"deadzone": 0.5,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":4194306,"physical_keycode":0,"key_label":0,"unicode":0,"location":0,"echo":false,"script":null)
]
}

[rendering]

; Pixel-art rendering — no filtering, no mipmaps.
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
textures/canvas_textures/default_texture_filter=0
2d/snap/snap_2d_transforms_to_pixel=true
2d/snap/snap_2d_vertices_to_pixel=true
